<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_estate_property_type_tree" model="ir.ui.view">
        <field name="name">estate.property.type.tree</field>
        <field name="model">estate.property.type</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence" widget="handle"/> <!-- Campo de secuencia para ordenar y handle significa que se puede arrastrar -->
                <field name="name"/>
                <field name="offer_count"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_estate_property_type_form" model="ir.ui.view">
        <field name="name">estate.property.type.form</field>
        <field name="model">estate.property.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(action_estate_property_offer)d"
                                type="action"
                                class="oe_stat_button"
                                icon="fa-list"
                                context="{'default_property_type_id': active_id}">
                            <div class="o_stat_info">
                                <field name="offer_count" widget="statinfo"/>
                                <span class="o_stat_text">Ofertas</span>
                            </div>
                        </button>
                    </div>

                    <group>
                        <field name="name"/>
                    </group>

                    <notebook>
                        <page string="Propiedades">
                            <field name="property_ids">
                                <tree editable="bottom">
                                    <field name="name"/>
                                    <field name="expected_price"/>
                                    <field name="bedrooms"/>
                                    <field name="living_area"/>
                                    <field name="date_availability"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_estate_property_type" model="ir.actions.act_window">
        <field name="name">Tipos de Propiedad</field>
        <field name="res_model">estate.property.type</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>