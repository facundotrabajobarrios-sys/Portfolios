<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_estate_property_tree" model="ir.ui.view">
        <field name="name">estate.property.tree</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <tree decoration-success="state == 'offer_received' or state == 'offer_accepted'"
                  decoration-bf="state == 'offer_accepted'"
                  decoration-muted="state == 'sold'">
                <field name="name"/>
                <field name="expected_price"/>
                <field name="bedrooms"/>
                <field name="living_area"/>
                <field name="date_availability" optional="hide"/>
                <field name="property_type_id"/><!-- Campo de relación many2one que muestra el tipo de propiedad -->
                <field name="tag_ids" widget="many2many_tags"/><!--con tag_ids se muestra el número de etiquetas-->
                <!-- widget="many2many_tags" muestra las etiquetas como etiquetas visuales en lugar de texto -->
                <field name="state" invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_estate_property_form" model="ir.ui.view"> <!-- ir.ui.view significa vista de interfaz de usuario-->
        <field name="name">estate.property.form</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <header>
                        <button name="action_sold" string="Vendido" type="object"
                                class="btn-primary" invisible="state in ('sold', 'canceled')"/>
                        <button name="action_cancel" string="Cancelar" type="object"
                                class="btn-secondary" invisible="state in ('sold', 'canceled')"/>
                        <field name="state" widget="statusbar"/> <!-- widget="statusbar" muestra el estado como una barra de progreso visual en lugar de texto -->
                    </header>
                    
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="description"/>
                            <field name="postal_code"/>
                            <field name="date_availability"/>
                            <field name="property_type_id"/>
                        </group>
                        <group>
                            <field name="expected_price"/>
                            <field name="selling_price"/>
                            <field name="best_price"/>
                        </group>
                    </group>

                    <group string="Características">
                        <group>
                            <field name="bedrooms"/>
                            <field name="living_area"/>
                            <field name="facades"/>
                        </group>
                        <group>
                            <field name="garage"/>
                            <field name="garden"/>
                            <field name="garden_area" invisible="not garden"/>
                            <field name="garden_orientation" invisible="not garden"/>
                            <field name="total_area"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Partes">
                            <group>
                                <group>
                                    <field name="seller_id"/>
                                </group>
                                <group>
                                    <field name="buyer_id"/>
                                </group>
                            </group>
                            <group string="Etiquetas">
                            <!-- widget="many2many_tags" muestra las etiquetas como etiquetas visuales en lugar de texto -->
                            <!-- options="{'color_field': 'color'}" hace que las etiquetas muestren un color basado en el campo color de estate.property.tag -->
                            <!-- El campo tag_ids es un campo many2many que relaciona la propiedad con sus etiquetas -->
                                <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                            </group>
                        </page>
                        <page string="Ofertas">
                            <field name="offer_ids" create="state not in ('offer_accepted', 'sold', 'canceled')"
                                   readonly="state in ('offer_accepted', 'sold', 'canceled')">
                                <tree>
                                    <field name="price"/>
                                    <field name="partner_id"/>
                                    <field name="status"/>
                                    <field name="validity" readonly="1"/>
                                    <field name="date_deadline"/>
                                    <button name="action_accept" string="Aceptar" type="object"
                                            icon="fa-check" class="btn-success"
                                            invisible="status != False"/>
                                    <button name="action_refuse" string="Rechazar" type="object"
                                            icon="fa-times" class="btn-danger"
                                            invisible="status != False"/><!-- Botones para aceptar o rechazar ofertas, solo visibles si la oferta no ha sido aceptada ni rechazada -->
                                </tree>
                                <form>
                                    <group>
                                        <field name="price"/>
                                        <field name="partner_id"/>
                                        <field name="status"/>
                                        <field name="validity" readonly="1"/>
                                        <field name="date_deadline"/>
                                    </group>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_estate_property_kanban" model="ir.ui.view">
        <field name="name">estate.property.kanban</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <kanban default_group_by="property_type_id" draggable="false">
                <field name="name"/>
                <field name="expected_price"/>
                <field name="best_price"/>
                <field name="selling_price"/>
                <field name="tag_ids"/>
                <field name="offer_ids"/>
                <field name="state"/>
                <field name="property_type_id"/>
                
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                </div>
                            </div>
                            
                            <div class="o_kanban_record_body">
                                <div>
                                    <strong>Precio esperado:</strong>
                                    <field name="expected_price" widget="monetary"/>
                                </div>
                                
                                <div t-if="record.offer_ids.raw_value and record.offer_ids.raw_value.length">
                                    <strong>Mejor oferta:</strong>
                                    <field name="best_price" widget="monetary"/>
                                </div>
                                
                                <div t-if="record.state.raw_value === 'offer_accepted' or record.state.raw_value === 'sold'">
                                    <strong>Precio de venta:</strong>
                                    <field name="selling_price" widget="monetary"/>
                                </div>
                                
                                <div t-if="record.tag_ids.raw_value and record.tag_ids.raw_value.length">
                                    <strong>Etiquetas:</strong>
                                    <field name="tag_ids" widget="many2many_tags"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_estate_property_search" model="ir.ui.view">
        <field name="name">estate.property.search</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="property_type_id"/>
                <field name="tag_ids"/>
                <filter name="filter_garage" string="Con Garaje" domain="[('garage','=',True)]"/>
                <filter name="filter_garden" string="Con Jardín" domain="[('garden','=',True)]"/>
                <filter name="filter_available" string="Disponibles" 
                        domain="['|', ('state', '=', 'new'), ('state', '=', 'offer_received')]"/>
                <group expand="0" string="Agrupar por">
                    <filter name="group_by_type" string="Tipo" context="{'group_by': 'property_type_id'}"/>
                    <filter name="group_by_state" string="Estado" context="{'group_by': 'state'}"/>
                    <filter name="group_by_postal" string="Código Postal" context="{'group_by': 'postal_code'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_estate_property" model="ir.actions.act_window">
        <field name="name">Propiedades</field>
        <field name="res_model">estate.property</field>
        <field name="view_mode">tree,form,kanban</field>
        <field name="domain">[]</field>
        <field name="context">{'search_default_filter_available': 1}</field>
        <!-- El contexto se utiliza para aplicar un filtro por defecto que muestre solo las propiedades disponibles al abrir la vista -->
    </record>
</odoo>